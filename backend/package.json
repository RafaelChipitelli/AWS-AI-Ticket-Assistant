{
  "name": "aws-ai-ticket-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/local/server.ts",
    "build": "tsc",
    "package": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path dist/lambda.zip) { Remove-Item dist/lambda.zip -Force }; Compress-Archive -Path dist,node_modules,package.json -DestinationPath dist/lambda.zip -Force\"",
    "start": "node dist/local/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1043.0",
    "@aws-sdk/lib-dynamodb": "^3.1043.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
